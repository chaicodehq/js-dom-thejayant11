    "test:win:watch": "set NODE_OPTIONS=--experimental-vm-modules&& jest --watchAll"
  },
  "keywords": [
    "javascript",
    "dom",
    "lab",
    "education"
  ],
  "license": "MIT",
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  }
}
