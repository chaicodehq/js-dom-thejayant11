{
  "name": "js-dom-lab",
  "version": "1.0.0",
  "description": "JavaScript DOM Manipulation Lab - Story-based exercises to master createElement, querySelector, classList, events, forms, traversal, and more",
  "type": "module",
  "scripts": {
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
